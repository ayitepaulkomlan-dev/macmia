# ── Chemins système ───────────────────────────────────────────────────────
# Laisser vide = détection automatique (Linux et Windows).
# Ne renseigner que si l'auto-détection échoue.
#   Windows : TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
#             POPPLER_PATH=C:\poppler\Library\bin
#   Linux   : apt install tesseract-ocr tesseract-ocr-fra poppler-utils
TESSERACT_CMD=
POPPLER_PATH=

# ── OCR ───────────────────────────────────────────────────────────────────
OCR_LANG=fra+eng
OCR_DPI=300

# ── Modèle de langue ──────────────────────────────────────────────────────
# Où tourne le modèle. « auto » essaie Ollama puis une API compatible OpenAI
# (llama-cpp-python, vLLM). Mettre « ollama » ou « openai » pour forcer.
LLM_PROVIDER=auto

# Adresse du serveur de modèle.
#   local        : http://localhost:11434
#   serveur GPU  : https://xxxx.ngrok-free.dev  (ou http://localhost:11434 via tunnel SSH)
OLLAMA_URL=http://localhost:11434

# Nom du modèle tel que le serveur le connaît (llama3.1, mistral, ministral-8b…)
OLLAMA_MODEL=llama3.1

# Délai d'attente en secondes. Sur GPU quelques secondes suffisent ;
# sans GPU un modèle 8B dépasse souvent 3 minutes.
OLLAMA_TIMEOUT=420
# Durée pendant laquelle le modèle reste chargé en mémoire entre deux analyses.
OLLAMA_KEEP_ALIVE=30m

# ── Import LinkedIn automatique (optionnel — voir README) ─────────────────
PROXYCURL_API_KEY=

# ── Origines autorisées supplémentaires, séparées par des virgules ────────
CORS_ORIGINS=
