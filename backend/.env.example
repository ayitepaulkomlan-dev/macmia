# Chemins système (laisser vide = détection automatique)
TESSERACT_CMD=
POPPLER_PATH=

# OCR
OCR_LANG=fra+eng
OCR_DPI=300

# LLM local (Ollama). Si indisponible, extraction en mode dégradé sans LLM.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Import LinkedIn automatique (optionnel — voir README)
PROXYCURL_API_KEY=

# Origines autorisées supplémentaires, séparées par des virgules
CORS_ORIGINS=
